# Adapter selection: "demo" (canned data, no ML stack) or "real".
ADAPTER_MODE=demo
DEMO_DELAY_SECONDS=1.5

# Analysis provider (real mode): "local" (faster-whisper + pyannote on-machine)
# or "assemblyai" (hosted transcription + diarization in one call — best for long meetings).
ANALYSIS_PROVIDER=local
ASSEMBLYAI_API_KEY=

# Transcription (faster-whisper) — used when ANALYSIS_PROVIDER=local
MODEL_SIZE=small
LANGUAGE=es
DEVICE=cpu
COMPUTE_TYPE=int8

# Diarization (pyannote.audio 4.x, local mode) — needs a free HF token AND accepting
# the gated terms for pyannote/speaker-diarization-community-1.
DIARIZATION_MODEL=pyannote/speaker-diarization-community-1
HUGGINGFACE_TOKEN=

# Minutes generation — provider: "gemini" (default) or "ollama" (local, OSS, private)
MINUTES_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

JOB_TTL_SECONDS=3600
