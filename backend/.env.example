# ActIA backend -- environment variables
# Copy this file to .env and fill in the values you need.

# General
ADAPTER_MODE=demo               # demo (canned data) or real (actual ML + LLM)
DEMO_DELAY_SECONDS=1.5          # Per-stage delay in demo mode (seconds)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000  # Comma-separated list of allowed CORS origins for production deployment

# Analysis provider
# local         -- faster-whisper + pyannote run on your machine
# assemblyai    -- hosted, good for long meetings (transcription + diarization in one call)
# speechmatics  -- hosted batch API, auto speaker detection, ~480 min/month free tier
ANALYSIS_PROVIDER=local

# AssemblyAI (required when ANALYSIS_PROVIDER=assemblyai)
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_SPEAKERS_EXPECTED=0  # 0 = auto-detect; set to known count to improve diarization

# Speechmatics (required when ANALYSIS_PROVIDER=speechmatics)
SPEECHMATICS_API_KEY=

# Local transcription (faster-whisper) -- used when ADAPTER_MODE=real and ANALYSIS_PROVIDER=local
MODEL_SIZE=small                # tiny | base | small | medium | large-v3
LANGUAGE=es                     # es, en, ... or auto
DEVICE=cpu                      # cpu | cuda
COMPUTE_TYPE=int8               # int8 (CPU) | float16 (GPU)

# Local diarization (pyannote.audio)
DIARIZATION_MODEL=pyannote/speaker-diarization-community-1
HUGGINGFACE_TOKEN=              # Required for pyannote -- generate at hf.co/settings/tokens

# Minutes generation
MINUTES_PROVIDER=gemini         # gemini | ollama
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Job retention
JOB_TTL_SECONDS=3600
