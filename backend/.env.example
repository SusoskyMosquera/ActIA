# Adapter selection: "demo" (canned data, no ML stack) or "real".
ADAPTER_MODE=demo
DEMO_DELAY_SECONDS=1.5

# Transcription (faster-whisper) — used when ADAPTER_MODE=real
MODEL_SIZE=small
LANGUAGE=es
DEVICE=cpu
COMPUTE_TYPE=int8

# Diarization (pyannote.audio) — needs a free HF token AND accepting the gated
# terms for pyannote/speaker-diarization-3.1 AND pyannote/segmentation-3.0.
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=

# Minutes generation — provider: "gemini" (default) or "ollama" (local, OSS, private)
MINUTES_PROVIDER=gemini
# gemini-2.5-flash recommended (1M TPM / 1500 RPD free tier; better than 1.5-flash)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
# For MINUTES_PROVIDER=ollama: install Ollama and run `ollama pull <OLLAMA_MODEL>`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

JOB_TTL_SECONDS=3600
